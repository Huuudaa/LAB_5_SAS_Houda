<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1">

    <TextView
        android:id="@+id/tvTitreDistance"
        android:text="@string/titre_conversion_dist"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#E65100"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>

    <RadioGroup
        android:id="@+id/rgDistance"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbKmToMiles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/km_to_miles"
            android:checked="true"
            android:textColor="#E65100"/>

        <RadioButton
            android:id="@+id/rbMilesToKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/miles_to_km"
            android:layout_marginStart="24dp"
            android:textColor="#E65100"/>

    </RadioGroup>

    <EditText
        android:id="@+id/etValeurDistance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/saisir_valeur"
        android:inputType="numberDecimal"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:autofillHints="no"/>

    <Button
        android:id="@+id/btnConvertirDistance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/convertir"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvResultatDistance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/resultat_vide"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#E65100"
        android:gravity="center"
        android:background="#FFE0B2"
        android:padding="12dp"/>

</LinearLayout>